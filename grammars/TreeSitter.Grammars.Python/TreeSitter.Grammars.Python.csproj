<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>TreeSitter.Grammars.Python</RootNamespace>
    <AssemblyName>TreeSitter.Grammars.Python</AssemblyName>

    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <Deterministic>true</Deterministic>

    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>TreeSitter.Grammars.Python</PackageId>
    <Authors>CodeAlive-AI</Authors>
    <Description>Strongly-typed tree-sitter node bindings for the Python grammar, generated by TreeSitter.CodeGen. Resolves the native grammar by name via TreeSitter.LanguagePack.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\TreeSitter\TreeSitter.csproj" />
    <ProjectReference Include="..\..\src\TreeSitter.LanguagePack\TreeSitter.LanguagePack.csproj" />
  </ItemGroup>

  <!--
    Dev/test convenience: copy the Python grammar native lib next to this assembly so
    the resolver's AssemblyDirectory probe finds libtree-sitter-python.so during
    `dotnet run`/`dotnet test`. Pack="false": the shipping grammar payload travels
    with the TreeSitter.LanguagePack package's runtimes/<rid>/native assets.
  -->
  <ItemGroup>
    <None Include="$(RepoRoot)native/$(NETCoreSdkPortableRuntimeIdentifier)/libtree-sitter-python.*"
          Condition="Exists('$(RepoRoot)native/$(NETCoreSdkPortableRuntimeIdentifier)')"
          CopyToOutputDirectory="PreserveNewest"
          Link="%(Filename)%(Extension)"
          Pack="false"
          Visible="false" />
  </ItemGroup>

</Project>
