<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>TreeSitter.Grammars.Json</RootNamespace>
    <AssemblyName>TreeSitter.Grammars.Json</AssemblyName>

    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <Deterministic>true</Deterministic>

    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>TreeSitter.Grammars.Json</PackageId>
    <Authors>CodeAlive-AI</Authors>
    <Description>Strongly-typed tree-sitter node bindings for the JSON grammar, generated by TreeSitter.CodeGen.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\TreeSitter\TreeSitter.csproj" />
  </ItemGroup>

  <!--
    Dev/test convenience: copy the JSON grammar native lib next to this assembly so
    the resolver's AssemblyDirectory probe finds libtree-sitter-json.so during
    `dotnet run`/`dotnet test`. Pack="false": shipping payload travels with the core
    package's runtimes/<rid>/native assets.
  -->
  <ItemGroup>
    <None Include="$(RepoRoot)native/$(NETCoreSdkPortableRuntimeIdentifier)/libtree-sitter-json.*"
          Condition="Exists('$(RepoRoot)native/$(NETCoreSdkPortableRuntimeIdentifier)')"
          CopyToOutputDirectory="PreserveNewest"
          Link="%(Filename)%(Extension)"
          Pack="false"
          Visible="false" />
  </ItemGroup>

</Project>
